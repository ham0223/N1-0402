CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_DNS2SOCKS_RUST=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_DNSPROXY=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_MosDNS=y
